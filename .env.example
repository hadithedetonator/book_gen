# ── Ollama (local LLM) ────────────────────────────────────────────────────────
# Name of the Ollama model to use. Must be pulled locally: ollama pull llama3
OLLAMA_MODEL=llama3
# Base URL of the Ollama HTTP server (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# ── SQLite (local database) ───────────────────────────────────────────────────
# Path to the SQLite database file. Directory will be created if missing.
SQLITE_DB_PATH=./data/books.db

# ── Local Output Directory ────────────────────────────────────────────────────
# All compiled .docx and .txt files are saved here under {book_id}/
OUTPUT_DIR=./outputs

# ── Gmail SMTP (STARTTLS on port 587) ────────────────────────────────────────
# Sender Gmail address
SMTP_EMAIL=you@gmail.com
# Gmail App Password (generate at Google Account → Security → App Passwords)
# Do NOT use your real Gmail password here.
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Recipient for all pipeline notifications
NOTIFY_EMAIL=recipient@example.com

# ── Optional tunables ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
